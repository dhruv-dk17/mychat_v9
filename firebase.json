{
  "hosting": {
    "public": "frontend",
    "ignore": ["firebase.json", "**/.*"],
    "rewrites": [
      { "source": "/chat", "destination": "/chat.html" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
      }
    ]
  }
}
