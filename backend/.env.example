# Mychat v9 Backend — Environment Variables
# Copy this to .env and fill in your values

# PostgreSQL connection string from Supabase (Session mode, port 5432)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to true if your DB requires SSL (Supabase does)
DB_SSL=true

# Admin secret for /admin/* routes (generate a long random string)
ADMIN_SECRET=change_me_to_something_very_secret_and_long

# Frontend URL (your Firebase Hosting URL)
FRONTEND_URL=https://mychat-v9.web.app

# Port (Render sets this automatically)
PORT=3001
